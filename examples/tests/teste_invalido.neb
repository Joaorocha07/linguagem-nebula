// ============================================
// TESTE 4: CÓDIGO INVÁLIDO (ERROS NÃO RECUPERÁVEIS)
// ============================================
// Este arquivo contém erros que devem ser detectados
// mas pode não executar completamente

// Erro léxico: caractere inválido
criar valor = 10 @ 5;

// Erro léxico: string não fechada
criar texto = "Isso é um teste;

// Erro sintático grave: palavra-chave desconhecida
seja x = 10;

// Erro sintático: estrutura completamente malformada
inicio
    criar a = 5
    se (a > 3)
        exibir("OK")
    senao
        exibir("NOK")
fim

// Código válido que não será alcançado devido aos erros anteriores
criar final = 100;
exibir(final);
